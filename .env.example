# LillianCare Helper — Environment Configuration
# Copy this file to .env and fill in the real values.
# .env is gitignored and must NEVER be committed.

# Database passwords per environment
DB_DEV_PASSWORD=
DB_STAGING_PASSWORD=
DB_PROD_PASSWORD=

# AES-256-CBC decryption key for guest appointment encryptedUserInfo (must be exactly 32 chars)
DECRYPT_KEY_DEV=
DECRYPT_KEY_STAGING=
DECRYPT_KEY_PROD=
