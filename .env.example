# LillianCare Helper — Environment Configuration
# Copy this file to .env and fill in the real values.
# .env is gitignored and must NEVER be committed.

# Database passwords per environment
DB_DEV_PASSWORD=
DB_STAGING_PASSWORD=
DB_PROD_PASSWORD=

# AES-256-CBC decryption key for guest appointment encryptedUserInfo (must be exactly 32 chars)
DECRYPT_KEY_DEV=
DECRYPT_KEY_STAGING=
DECRYPT_KEY_PROD=

# PMS (principa FHIR) — base URLs per environment
# Examples: http://localhost:8080/fhir4/ , http://172.16.2.20:8080/fhir4/ ,
#           https://principa-test.aws.lillian-care.de/fhir4/ , https://principa.aws.lillian-care.de/fhir4/
PMS_BASE_URL_DEV=
PMS_BASE_URL_STAGING=
PMS_BASE_URL_PROD=

# PMS HS256 signing secrets (same values Serverpod loads as principaTestSecret / principaProdSecret).
# Test secret is reused for dev + staging to mirror the backend's flavor mapping.
PMS_SECRET_TEST=
PMS_SECRET_PROD=

# Google Business Profile (GBP) — OAuth 2.0 Web application credentials.
# These power the "Google Business" view in the helper and will later be
# mirrored by the Dart admin console with its own OAuth client.
#
# One-time Google Cloud Console setup (do this under a Google account that
# is an Owner or Manager on the GBP account you want to manage):
#   1. console.cloud.google.com → create/select a project.
#   2. Request access to the Business Profile APIs:
#      https://support.google.com/business/contact/api_default
#      (Business Information API is gated — PATCH calls will return
#       PERMISSION_DENIED until Google approves the form.)
#   3. APIs & Services → Library → enable:
#        • My Business Account Management API
#        • My Business Business Information API
#   4. APIs & Services → OAuth consent screen:
#        • User type: External
#        • Scope: https://www.googleapis.com/auth/business.manage
#        • Add your Google email as a test user
#   5. APIs & Services → Credentials → Create OAuth 2.0 Client ID:
#        • Application type: Web application
#        • Authorized redirect URIs: http://localhost:3333/api/gbp/oauth/callback
#   6. Copy the Client ID + Client Secret below.
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=
